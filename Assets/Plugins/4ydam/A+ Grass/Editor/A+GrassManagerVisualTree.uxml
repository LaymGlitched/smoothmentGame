            <ui:Label text="i" tooltip="Extra distance added beyond Fade End before renderer is culled to avoid visible popping." style="margin-top: 0; margin-right: 10px; margin-bottom: 7px; margin-left: 10px; padding-top: 0; padding-right: 5px; padding-bottom: 0; padding-left: 5px; align-self: flex-end; justify-content: center; align-content: center; align-items: flex-end; -unity-font-style: bold; white-space: nowrap; -unity-text-align: middle-center; background-color: rgb(255, 255, 255); color: rgb(0, 0, 0); border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px;"/>
            <ui:Label text="Cull Padding" style="margin-top: 0; margin-right: 0; margin-bottom: 7px; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; align-self: flex-end; justify-content: center; align-content: center; align-items: flex-end; -unity-font-style: normal; white-space: nowrap; -unity-text-align: middle-left;"/>
            <ui:VisualElement style="flex-grow: 1; flex-direction: row; justify-content: flex-end;">
                <ui:Slider label="" value="0.5" low-value="0" high-value="5" binding-path="rendererCullPadding" fill="true" show-input-field="false" direction="Horizontal" style="width: 125px; margin-right: 5px; align-items: flex-start; align-self: center; justify-content: center; align-content: center; margin-left: 5px; margin-bottom: 0; margin-top: 0; height: 20px;"/>
                <ui:FloatField label="" value="0.5" binding-path="rendererCullPadding" max-length="10" style="width: 45px;"/>
